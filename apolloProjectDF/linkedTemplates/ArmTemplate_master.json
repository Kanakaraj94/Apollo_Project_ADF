{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "apolloProjectDF"
		},
		"Adf2AzSql_ls_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'Adf2AzSql_ls'"
		},
		"Adls2Adf_ls_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://apolloadlsdata.dfs.core.windows.net/"
		},
		"AzureKeyVault_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://ApolloKeyVaultStore.vault.azure.net/"
		},
		"Blob2Adf_ls_properties_typeProperties_connectionString_secretName": {
			"type": "string",
			"defaultValue": "BlobConnStr"
		},
		"MySql2Adf_ls_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "localhost"
		},
		"MySql2Adf_ls_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "apollo_db"
		},
		"MySql2Adf_ls_properties_typeProperties_username": {
			"type": "string",
			"defaultValue": "root"
		},
		"Adf2AzSql_ls_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "apolloproject.database.windows.net"
		},
		"Adf2AzSql_ls_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "apollo_db"
		},
		"Adf2AzSql_ls_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "apollo_admin"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "apolloProjectDF_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"Adf2AzSql_ls_password": {
						"value": "[parameters('Adf2AzSql_ls_password')]"
					},
					"AzureKeyVault_properties_typeProperties_baseUrl": {
						"value": "[parameters('AzureKeyVault_properties_typeProperties_baseUrl')]"
					},
					"Adf2AzSql_ls_properties_typeProperties_server": {
						"value": "[parameters('Adf2AzSql_ls_properties_typeProperties_server')]"
					},
					"Adf2AzSql_ls_properties_typeProperties_database": {
						"value": "[parameters('Adf2AzSql_ls_properties_typeProperties_database')]"
					},
					"Adf2AzSql_ls_properties_typeProperties_userName": {
						"value": "[parameters('Adf2AzSql_ls_properties_typeProperties_userName')]"
					},
					"Adls2Adf_ls_properties_typeProperties_url": {
						"value": "[parameters('Adls2Adf_ls_properties_typeProperties_url')]"
					},
					"Blob2Adf_ls_properties_typeProperties_connectionString_secretName": {
						"value": "[parameters('Blob2Adf_ls_properties_typeProperties_connectionString_secretName')]"
					},
					"MySql2Adf_ls_properties_typeProperties_server": {
						"value": "[parameters('MySql2Adf_ls_properties_typeProperties_server')]"
					},
					"MySql2Adf_ls_properties_typeProperties_database": {
						"value": "[parameters('MySql2Adf_ls_properties_typeProperties_database')]"
					},
					"MySql2Adf_ls_properties_typeProperties_username": {
						"value": "[parameters('MySql2Adf_ls_properties_typeProperties_username')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "apolloProjectDF_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'apolloProjectDF_ArmTemplate_0')]"
			]
		}
	]
}