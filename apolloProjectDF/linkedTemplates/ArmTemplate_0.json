{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "apolloProjectDF"
		},
		"AzureKeyVault_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://ApolloKeyVaultStore.vault.azure.net/"
		},
		"Adls2Adf_ls_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://apolloadlsdata.dfs.core.windows.net/"
		},
		"Blob2Adf_ls_properties_typeProperties_connectionString_secretName": {
			"type": "string",
			"defaultValue": "BlobConnStr"
		},
		"MySql2Adf_ls_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "localhost"
		},
		"MySql2Adf_ls_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "apollo_db"
		},
		"MySql2Adf_ls_properties_typeProperties_username": {
			"type": "string",
			"defaultValue": "root"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
