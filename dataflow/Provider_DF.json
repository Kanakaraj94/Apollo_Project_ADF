{
	"name": "Provider_DF",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "Provider_B",
						"type": "DatasetReference"
					},
					"name": "ProviderData"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "Provider_S",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "flatten1"
				},
				{
					"name": "Json2TableFormat"
				}
			],
			"scriptLines": [
				"source(output(",
				"          Sheet1 as (prov_id as short, prov_loc_id as short, prov_name as string, prov_spec as string)[]",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     documentForm: 'arrayOfDocuments') ~> ProviderData",
				"ProviderData foldDown(unroll(Sheet1),",
				"     mapColumn(",
				"          Sheet1",
				"     ),",
				"     skipDuplicateMapInputs: false,",
				"     skipDuplicateMapOutputs: false) ~> flatten1",
				"flatten1 select(mapColumn(",
				"          prov_id = Sheet1.prov_id,",
				"          prov_loc_id = Sheet1.prov_loc_id,",
				"          prov_name = Sheet1.prov_name,",
				"          prov_spec = Sheet1.prov_spec",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> Json2TableFormat",
				"Json2TableFormat sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          dx_enc_id as string,",
				"          dx_line as string,",
				"          dx_icd as string",
				"     ),",
				"     filePattern:'Provider_Table_S.csv',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}