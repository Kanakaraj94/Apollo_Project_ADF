{
	"name": "Encounter_Dx_DF",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "Encounter_Dx_B",
						"type": "DatasetReference"
					},
					"name": "EncounterDxData"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "Encounter_Dx_S",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          dx_enc_id as string,",
				"          dx_line as string,",
				"          dx_icd as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> EncounterDxData",
				"EncounterDxData sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          enc_id as string,",
				"          enc_patient_id as string,",
				"          visit_prov_id as string,",
				"          enc_status as string,",
				"          enc_date as string,",
				"          due_date as string",
				"     ),",
				"     filePattern:'Encounter_Dx_Table_S.csv',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}